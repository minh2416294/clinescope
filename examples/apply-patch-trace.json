{
  "version": 1,
  "sessionId": "example-apply-patch-01",
  "messages": [
    {
      "role": "user",
      "content": [
        { "type": "text", "text": "Create note.txt containing the word hello." }
      ]
    },
    {
      "role": "assistant",
      "content": [
        {
          "type": "thinking",
          "thinking": "Check the directory first, then add the file with apply_patch."
        },
        {
          "type": "tool_use",
          "id": "call-1",
          "name": "read_files",
          "input": { "path": "note.txt" }
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "tool_result",
          "tool_use_id": "call-1",
          "content": "Error: file not found",
          "is_error": true
        }
      ]
    },
    {
      "role": "assistant",
      "content": [
        {
          "type": "tool_use",
          "id": "call-2",
          "name": "apply_patch",
          "input": {
            "input": "*** Begin Patch\n*** Add File: note.txt\n+hello\n*** End Patch"
          }
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "tool_result",
          "tool_use_id": "call-2",
          "content": "Successfully applied patch to the following files:\nnote.txt",
          "is_error": false
        }
      ]
    }
  ]
}
